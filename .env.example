# Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Your Telegram user ID or admin group chat ID (numeric)
ADMIN_CHAT_ID=123456789

# Optional: admin contact shown in Support menu (without @)
SUPPORT_HANDLE=your_admin_username

# Optional: path to SQLite database file
DB_PATH=./data/bot.db
